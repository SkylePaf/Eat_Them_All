{
  "name": "eathemall",
  "version": "1.1.0",
  "author": {
    "name": "Skylepaf",
    "email": "skylepaf@gmail.com"
  },
  "description": "EatThemAll - Stupid game where you eat cubes",
  "homepage": "https://github.com/Skylepaf/Eat_Them_All",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.EatThemAll.app",
    "productName": "EatThemAll",
    "files": ["main.js", "src/**/*"],
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "src/assets/icon.png",
      "category": "Education"
    },
    "win": {
      "target": ["nsis"],
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/assets/icon.icns"
    }
  }
}
